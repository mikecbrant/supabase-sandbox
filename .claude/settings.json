{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "us.anthropic.claude-sonnet-4-6"
  },
  "permissions": {
    "allow": [
      "Bash(date *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(pnpm build *)",
      "Bash(pnpm dev *)",
      "Bash(pnpm install *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm supabase:diff *)",
      "Bash(pnpm supabase:lint *)",
      "Bash(pnpm supabase:migrations *)",
      "Bash(pnpm supabase:migration:new *)",
      "Bash(pnpm supabase:reset *)",
      "Bash(pnpm supabase:start *)",
      "Bash(pnpm supabase:status *)",
      "Bash(pnpm supabase:stop *)",
      "Bash(pnpm supabase:types *)",
      "Bash(pnpm typecheck *)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:supabase.com)"
    ],
    "deny": [
      "Read(.claude/settings.local.json)",
      "Read(.env)",
      "Read(.env*.local)",
      "Read(.env.local)"
    ]
  }
}
